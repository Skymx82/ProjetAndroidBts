<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AffPlanning">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- LIGNE CALENDRIER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CalendarView
                android:id="@+id/calendarPlanning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- LIGNE BOUTON AFFICHER RDV -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnAfficherRdv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Afficher les RDV" />
        </LinearLayout>

        <!-- LIGNE SPINNER RDV -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerRdv"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- ================= NAVIGATION ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:paddingTop="8dp">

            <Button
                android:id="@+id/btnNavAccueil"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Accueil"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnNavRdv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RDV"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnNavPlanning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Planning"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnNavMedecins"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Médecins"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />
        </LinearLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
