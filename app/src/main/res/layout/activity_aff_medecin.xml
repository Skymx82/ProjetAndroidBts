<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AffMedecin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- LIGNE VILLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ville :"
                android:layout_gravity="center_vertical" />

            <EditText
                android:id="@+id/editVille"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:inputType="textPersonName" />
        </LinearLayout>

        <!-- LIGNE CODE POSTAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Code postal :"
                android:layout_gravity="center_vertical" />

            <EditText
                android:id="@+id/editCodePostal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:inputType="number" />
        </LinearLayout>

        <!-- LIGNE BOUTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnAfficherMedecins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:onClick="affPro"
                android:text="Afficher les médecins" />
        </LinearLayout>

        <!-- LIGNE SPINNER MEDECINS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerMedecins"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- ================= NAVIGATION ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:paddingTop="8dp">

            <Button
                android:id="@+id/btnNavAccueil"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Accueil"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnNavRdv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RDV"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnNavPlanning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Planning"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnNavMedecins"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Médecins"
                android:textSize="12sp"
                android:minHeight="36dp"
                android:padding="4dp"
                android:singleLine="true" />
        </LinearLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
